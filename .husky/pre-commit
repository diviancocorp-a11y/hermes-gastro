# ── Hermes pre-commit ────────────────────────────────────
# 1. Valida integridad de archivos (no truncados, no null bytes, JSON parsea)
# 2. Corre eslint en archivos staged
# 3. Corre tsc --noEmit global (rápido, ~3s)
# 4. Smoke test unitario (~5s)
#
# Tiempo total esperado: ~10-15s.

set -e

# Lista de archivos staged que vamos a verificar
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|jsx|ts|tsx|mjs|cjs|json)$' || true)

if [ -n "$STAGED_FILES" ]; then
  echo "→ Verificando integridad de $(echo "$STAGED_FILES" | wc -l) archivo(s)..."
  echo "$STAGED_FILES" | xargs node scripts/check-file-integrity.mjs

  echo "→ Corriendo lint-staged..."
  npx lint-staged
fi

echo "→ Typecheck..."
npm run typecheck

echo "→ Smoke unit tests..."
npx vitest run src/test/utils.test.js src/test/schemas.test.js --no-coverage --silent
