# ── Hermes pre-commit ────────────────────────────────────
# 1. Auto-arregla trailing newline en archivos staged (--fix)
# 2. Valida integridad (rechaza NULL bytes, JSON/JS rotos)
# 3. Corre eslint sobre archivos staged (lint-staged)
# 4. Typecheck global
# 5. Smoke unit tests
#
# Tiempo total esperado: ~10-15s.

set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|jsx|ts|tsx|mjs|cjs|json)$' || true)

if [ -n "$STAGED_FILES" ]; then
  echo "→ Verificando + auto-fix integridad de $(echo "$STAGED_FILES" | wc -l) archivo(s)..."
  echo "$STAGED_FILES" | xargs node scripts/check-file-integrity.mjs --fix

  echo "→ Corriendo lint-staged..."
  npx lint-staged
fi

echo "→ Schema ↔ DB sync..."
node scripts/check-schema-sync.mjs

echo "→ Typecheck..."
npm run typecheck

echo "→ Smoke unit tests..."
npx vitest run src/test/utils.test.js src/test/schemas.test.js --no-coverage --silent
