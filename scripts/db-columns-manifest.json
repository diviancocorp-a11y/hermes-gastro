        "catalog_payment_methods",
        "catalog_theme",
        "slogan",
        "whatsapp",
        "instagram",
        "facebook",
        "tiktok",
        "youtube",
        "twitter",
        "linkedin",
        "favicon_url",
        "cover_url",
        "og_image_url",
        "has_physical_store",
        "store_address",
        "min_order_amount",
        "cat_groups",
        "daily_deals",
        "deal_pct",
