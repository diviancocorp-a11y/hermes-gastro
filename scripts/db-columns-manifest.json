{
  "$comment": "Mapeo de tabla DB -> columnas que el schema Zod DEBE conocer. Si agregas una columna a la DB que se va a poder guardar desde el cliente, agregala aca Y al schema Zod correspondiente. Las columnas autogeneradas (id, created_at, updated_at) o calculadas server-side se ponen en 'serverOnly' para que el script no las exija al schema.",
  "tables": {
    "settings": {
      "schema": "SettingsInputSchema",
      "columns": [
        "biz_name",
        "logo_letter",
        "logo_color",
        "logo_url",
        "cat_images",
        "hidden_cats",
        "cat_names",
        "banner_text",
        "banner_color",
        "store_open",
        "store_hours",
        "exp_cats",
        "ing_cats",
        "waste_pct",
        "expense_pct",
        "payment_methods",
        "catalog_payment_methods",
        "payment_accounts",
        "catalog_theme",
        "slogan",
        "whatsapp",
        "instagram",
        "facebook",
        "tiktok",
        "youtube",
        "twitter",
        "linkedin",
        "favicon_url",
        "cover_url",
        "og_image_url",
        "has_physical_store",
        "store_address",
        "min_order_amount",
        "delivery_pricing",
        "coupon_default_pct",
        "birthday_coupon_pct",
        "cat_groups",
        "daily_deals",
        "deal_pct",
        "store_name",
        "app_url"
      ],
      "serverOnly": [
        "id",
        "prep_time_min",
        "delivery_time_min",
        "show_hours_on_catalog",
        "catalog_font",
        "usar_targets"
      ]
    },
    "ingredients": {
      "schema": "IngredientInputSchema",
      "columns": [
        "name",
        "unit",
        "cost",
        "stock",
        "min_stock",
        "category",
        "food_category",
        "is_archived"
      ],
      "serverOnly": [
        "id",
        "created_at",
        "updated_at"
      ]
    },
    "expenses": {
      "$comment": "Bug Zod-strip #6: usar_category/expense_type/receipt/items estaban en serverOnly pero el form los envia -> se perdian. TODO campo que el form de Gastos o Compras envia DEBE estar en columns.",
      "schema": "ExpenseInputSchema",
      "columns": [
        "date",
        "description",
        "amount",
        "category",
        "supplier",
        "expense_type",
        "usar_category",
        "supplier_id",
        "receipt_url",
        "no_receipt",
        "payment_method",
        "payment_account_id",
        "items",
        "notes",
        "created_by",
        "installment_current",
        "installment_total"
      ],
      "serverOnly": [
        "id",
        "created_at",
        "voided_at",
        "voided_by",
        "voids_expense_id",
        "voided_reason",
        "delivery_channel",
        "platform_commission_amt"
      ]
    },
    "sales": {
      "schema": "SaleInputSchema",
      "columns": [
        "date",
        "recipe_id",
        "qty",
        "unit_price",
        "unit_cost"
      ],
      "serverOnly": [
        "id",
        "created_at",
        "total"
      ]
    },
    "orders": {
      "$comment": "TODO campo que el checkout envia DEBE estar en columns (= declarado en OrderInputSchema). serverOnly es SOLO para columnas calculadas por la edge function. El bug #5 (delivery_address perdida) paso porque address estaba mal clasificada como serverOnly.",
      "schema": "OrderInputSchema",
      "columns": [
        "customer",
        "phone",
        "email",
        "delivery",
        "payment",
        "payment_account_id",
        "note",
        "items",
        "coupon_code",
        "is_gift",
        "gift_note",
        "delivery_date",
        "user_id",
        "address",
        "delivery_cost",
        "tip_pct"
      ],
      "serverOnly": [
        "id",
        "created_at",
        "date",
        "status",
        "total",
        "discount",
        "tip_amount",
        "coupon_id",
        "delivery_address",
        "payment_account_snapshot",
        "receipt_url",
        "receipt_verified",
        "tracking_token",
        "delivery_channel",
        "platform_commission_amt"
      ]
    },
    "purchases": {
      "schema": "PurchaseInputSchema",
      "columns": [
        "date",
        "supplier",
        "total"
      ],
      "serverOnly": [
        "id",
        "created_at",
        "supplier_id",
        "receipt_url",
        "no_receipt",
        "payment_method"
      ]
    }
  }
}
